# ===========================================
# Silver Yard Care Club — Environment Variables
# ===========================================
# Set these in your Railway dashboard.

# Port (Railway sets PORT automatically)
PORT=3456

# --- Email Notifications ---
NOTIFY_EMAIL=Zeph@survivormountain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# --- Stripe (get at dashboard.stripe.com) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Twilio SMS (get at console.twilio.com) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Google Calendar (service account JSON) ---
# Either set this env var OR place google-key.json in project root
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary
